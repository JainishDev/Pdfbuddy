---
// src/pages/index.astro
// Composition root: lays out the components in order and loads the
// (also modular) client-side scripts. No markup, styling, or business
// logic lives directly in this file anymore.
import Layout from '../layouts/Layout.astro';
import BootScreen from '../components/BootScreen.astro';
import TopBar from '../components/TopBar.astro';
import UploadScreen from '../components/UploadScreen.astro';
import ChatScreen from '../components/ChatScreen.astro';
import RobotMascot from '../components/RobotMascot.astro';
---
<Layout>
  <BootScreen />

  <main id="app" class="app hidden">
    <TopBar />
    <UploadScreen />
    <ChatScreen />
    <RobotMascot />
  </main>
</Layout>

<style>
  .app {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    animation: appIn 0.5s ease-out;
  }
</style>

<script>
  import '../scripts/main';
</script>
