---
// src/components/TopBar.astro
// App header: brand mark on the left, theme toggle + active-document
// badge + "new PDF" on the right.
// Interactivity lives in src/scripts/chrome.ts and src/scripts/upload.ts
---

<header class="topbar">
  <div class="brand-wrap">
    <div class="brand pixel-font">
      <span class="brand-icon" aria-hidden="true"></span>
      <span class="brand-name">PDF Buddy</span>
    </div>
    <span class="brand-sub">Ask your PDF anything</span>
    <span class="status-dot" title="Systems online"></span>
  </div>
  <div class="topbar-right">
    <button id="theme-toggle" class="theme-toggle" type="button" aria-pressed="false" title="Toggle light / dark mode">
      <span class="theme-toggle-track">
        <span class="theme-track-icon sun-glyph" aria-hidden="true"></span>
        <span class="theme-track-icon moon-glyph" aria-hidden="true"></span>
        <span class="theme-toggle-thumb">
          <span class="thumb-core" aria-hidden="true"></span>
        </span>
      </span>
    </button>
    <span id="doc-badge" class="doc-badge hidden"></span>
    <button id="new-doc-btn" class="btn-mini pixel-font hidden">New PDF</button>
    <div class="recent-docs-wrap">
      <button id="recent-docs-btn" class="account-btn" type="button" title="PDF history" aria-haspopup="true" aria-expanded="false">
        History<span id="recent-docs-count" class="recent-docs-count hidden">0</span>
      </button>
      <div id="recent-docs-panel" class="recent-docs-panel hidden">
        <div class="recent-docs-header">
          <span>History (this browser)</span>
          <button id="recent-docs-clear" class="recent-docs-clear hidden" type="button">Clear all</button>
        </div>
        <div id="recent-docs-empty" class="recent-docs-empty hidden">No PDFs yet — upload one to see it here.</div>
        <div id="recent-docs-list" class="recent-docs-list"></div>
      </div>
    </div>
    <button id="account-btn" class="account-btn pixel-font" type="button" title="Account">
      <span id="account-btn-label">Sign In</span>
    </button>
  </div>
</header>

<div id="account-modal" class="account-modal-overlay hidden" role="dialog" aria-modal="true" aria-labelledby="account-modal-title">
  <div class="account-modal">
    <button class="account-modal-close" id="account-modal-close" type="button" aria-label="Close">×</button>

    <div id="account-modal-guest">
      <h2 id="account-modal-title" class="pixel-font account-modal-title">Save your account</h2>
      <p class="account-modal-sub">Sign in to keep your preferences across devices. Your PDFs and chats stay in this browser tab either way.</p>

      <button class="account-btn-google" id="account-google-btn" type="button">Continue with Google</button>

      <div class="account-divider"><span>or</span></div>

      <form id="account-email-form" class="account-email-form">
        <input class="account-input" id="account-email" type="email" placeholder="Email" autocomplete="email" required />
        <input class="account-input" id="account-password" type="password" placeholder="Password" autocomplete="current-password" minlength="6" required />
        <div id="account-error" class="account-error hidden"></div>
        <button class="account-btn-primary" id="account-submit-btn" type="submit">Sign In</button>
      </form>

      <p class="account-switch">
        <span id="account-switch-text">New here?</span>
        <button type="button" id="account-switch-btn" class="account-link-btn">Create an account</button>
      </p>
    </div>

    <div id="account-modal-signedin" class="hidden">
      <h2 class="pixel-font account-modal-title">You're signed in</h2>
      <p class="account-modal-sub" id="account-signedin-email">—</p>
      <button class="account-btn-primary" id="account-signout-btn" type="button">Sign out</button>
    </div>
  </div>
</div>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 14px 24px;
    background:
      linear-gradient(90deg, rgba(120, 183, 255, 0.09), transparent 42%, rgba(80, 227, 194, 0.08)),
      color-mix(in srgb, var(--panel-solid) 76%, transparent);
    backdrop-filter: blur(20px) saturate(1.2);
    border-bottom: 1px solid var(--border);
    box-shadow: 0 12px 42px rgba(0, 0, 0, 0.2);
  }
  :global(html[data-theme='light']) .topbar {
    background:
      linear-gradient(90deg, rgba(255, 211, 138, 0.44), rgba(222, 214, 255, 0.76), rgba(194, 238, 241, 0.58)),
      rgba(245, 239, 255, 0.9);
    box-shadow: 0 12px 34px rgba(37, 44, 96, 0.16);
  }
  .brand-wrap {
    position: relative;
    display: grid;
    grid-template-columns: auto auto;
    column-gap: 10px;
    row-gap: 1px;
    align-items: center;
    min-width: 0;
  }
  .brand { font-size: 18px; color: var(--white); display: flex; align-items: center; gap: 8px; }
  .brand-name { white-space: nowrap; }
  .brand-sub {
    grid-column: 2;
    color: var(--muted);
    font-size: 11px;
    line-height: 1;
    white-space: nowrap;
  }
  .brand-icon {
    position: relative;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--mint), var(--sky) 46%, var(--purple));
    box-shadow: var(--glow-purple);
    display: inline-block;
  }
  .brand-icon::after {
    content: '';
    position: absolute;
    left: -5px;
    right: -5px;
    top: 11px;
    height: 7px;
    border: 1px solid rgba(247, 249, 255, 0.65);
    border-left-color: transparent;
    border-right-color: transparent;
    border-radius: 50%;
    transform: rotate(-16deg);
  }
  .topbar-right { display: flex; align-items: center; gap: 12px; }
  .doc-badge {
    font-size: 12px;
    background: var(--panel-soft);
    border: 1px solid var(--border);
    color: var(--sky);
    border-radius: 999px;
    padding: 6px 14px;
    max-width: 220px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(html[data-theme='light']) .doc-badge {
    background: rgba(255, 247, 234, 0.86);
    border-color: rgba(55, 59, 125, 0.28);
    color: #165894;
  }
  .btn-mini {
    font-size: 13px;
    background: linear-gradient(135deg, var(--purple), var(--sky));
    color: var(--button-text);
    border: none;
    border-radius: 999px;
    padding: 9px 16px;
    box-shadow: var(--glow-purple);
    transition: transform 0.15s ease;
  }
  .btn-mini:hover { transform: translateY(-2px); }
  .btn-mini:active { transform: translateY(0); }

  .status-dot {
    grid-column: 1;
    grid-row: 2;
    justify-self: center;
    width: 8px;
    height: 8px;
    margin-left: 0;
    border-radius: 50%;
    background: var(--mint);
    box-shadow: 0 0 8px rgba(53, 240, 192, 0.9);
    animation: statusPulse 1.8s ease-in-out infinite;
    display: inline-block;
  }
  @keyframes statusPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.6); opacity: 0.5; }
  }

  /* ---- theme toggle (sun/moon pill switch) ---- */
  .theme-toggle {
    background: transparent;
    border: none;
    padding: 0;
    line-height: 0;
  }
  .theme-toggle-track {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    width: 74px;
    height: 36px;
    border-radius: 999px;
    background:
      radial-gradient(circle at 22% 50%, rgba(120, 183, 255, 0.24), transparent 28%),
      linear-gradient(135deg, #121a33, #23194b);
    border: 1px solid var(--border);
    padding: 5px 9px;
    position: relative;
    box-shadow: inset 0 1px 9px rgba(0, 0, 0, 0.28), var(--glow-purple);
    overflow: hidden;
    transition: background 0.55s ease, border-color 0.55s ease, box-shadow 0.55s ease;
  }
  :global(html[data-theme='light']) .theme-toggle-track {
    background:
      radial-gradient(circle at 72% 45%, rgba(255, 198, 92, 0.58), transparent 28%),
      linear-gradient(135deg, #fff0bd, #cbe9ef 54%, #dcd5ff);
    border-color: rgba(55, 59, 125, 0.28);
    box-shadow: inset 0 1px 8px rgba(255, 255, 255, 0.45), var(--glow-pink);
  }
  .theme-toggle-thumb {
    position: absolute;
    left: 5px;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background:
      radial-gradient(circle at 36% 32%, rgba(255, 255, 255, 0.75), transparent 0 18%, transparent 19%),
      linear-gradient(135deg, var(--purple), var(--pink));
    box-shadow: var(--glow-purple);
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translateX(0);
    transition: transform 0.58s cubic-bezier(0.2, 0.9, 0.2, 1.18), background 0.55s ease, box-shadow 0.55s ease;
    z-index: 2;
  }
  .thumb-core {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
    box-shadow: -6px -4px 0 -3px rgba(255, 255, 255, 0.44), 5px 4px 0 -4px rgba(255, 255, 255, 0.34);
    transition: transform 0.55s ease, background 0.55s ease, box-shadow 0.55s ease;
  }
  .theme-track-icon {
    position: absolute;
    top: 50%;
    translate: 0 -50%;
    z-index: 1;
    opacity: 0.72;
  }
  .sun-glyph {
    right: 11px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #ffd26a;
    box-shadow: 0 -7px 0 -5px #ffd26a, 0 7px 0 -5px #ffd26a, 7px 0 0 -5px #ffd26a, -7px 0 0 -5px #ffd26a;
  }
  .moon-glyph {
    left: 12px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #d9e6ff;
    box-shadow: inset -5px 0 0 #8d7cff;
  }

  :global(html[data-theme='light']) .theme-toggle-thumb {
    transform: translateX(38px);
    background:
      radial-gradient(circle at 35% 32%, rgba(255, 255, 255, 0.88), transparent 0 16%, transparent 17%),
      linear-gradient(135deg, #ffcc58, #ef6f9d);
    box-shadow: var(--glow-pink);
  }
  :global(html[data-theme='light']) .thumb-core {
    transform: scale(0.62);
    background: rgba(255, 255, 255, 0.42);
    box-shadow: 0 0 0 5px rgba(255, 222, 130, 0.28), 0 0 0 10px rgba(255, 222, 130, 0.12);
  }

  @media (max-width: 620px) {
    .topbar {
      align-items: flex-start;
      gap: 12px;
      padding: 12px 14px;
    }
    .brand-wrap { column-gap: 8px; }
    .brand { font-size: 16px; min-width: 0; }
    .brand-sub { display: none; }
    .brand-icon { width: 24px; height: 24px; }
    .brand-icon::after { top: 9px; }
    .topbar-right {
      justify-content: flex-end;
      flex-wrap: wrap;
      gap: 8px;
    }
    .theme-toggle-track { width: 66px; height: 34px; }
    :global(html[data-theme='light']) .theme-toggle-thumb { transform: translateX(30px); }
    .doc-badge {
      order: 3;
      max-width: min(58vw, 220px);
      font-size: 11px;
      padding: 6px 10px;
    }
    .btn-mini { font-size: 12px; padding: 8px 12px; }
  }

  /* ---- account button + modal ---- */
  .account-btn {
    font-size: 13px;
    background: var(--panel-soft);
    color: var(--white);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 9px 16px;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .account-btn:hover { transform: translateY(-2px); border-color: var(--sky); }
  .account-btn.is-signed-in {
    background: linear-gradient(135deg, var(--mint), var(--sky));
    color: var(--button-text);
    border: none;
  }

  .account-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(5, 6, 26, 0.6);
    backdrop-filter: blur(6px);
    padding: 20px;
    opacity: 1;
    transition: opacity 0.22s ease;
  }
  .account-modal-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }
  .account-modal {
    width: 100%;
    max-width: 360px;
    background: var(--panel-solid);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px 24px 24px;
    box-shadow: var(--card-shadow), var(--glow-purple);
    position: relative;
    animation: accountModalIn 0.28s cubic-bezier(0.2, 0.9, 0.2, 1.1);
  }
  .account-modal-overlay.hidden .account-modal { animation: none; }
  @keyframes accountModalIn {
    from { opacity: 0; transform: scale(0.94) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .account-modal-close {
    position: absolute;
    top: 12px;
    right: 14px;
    background: none;
    border: none;
    color: var(--muted);
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    padding: 4px;
  }
  .account-modal-close:hover { color: var(--white); }
  .account-modal-title { font-size: 16px; margin: 0 0 8px; color: var(--white); }
  .account-modal-sub { font-size: 13px; color: var(--muted); line-height: 1.5; margin: 0 0 18px; }
  .account-btn-google {
    width: 100%;
    padding: 11px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--panel-soft);
    color: var(--white);
    font-size: 13.5px;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .account-btn-google:hover { transform: translateY(-1px); border-color: var(--sky); }
  .account-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 16px 0;
    color: var(--muted);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .account-divider::before,
  .account-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .account-email-form { display: flex; flex-direction: column; gap: 10px; }
  .account-input {
    background: var(--panel-soft);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 11px 13px;
    font-size: 13.5px;
    color: var(--white);
    transition: border-color 0.15s ease;
  }
  .account-input:focus { outline: none; border-color: var(--sky); }
  .account-error {
    font-size: 12px;
    color: var(--pink);
    background: rgba(255, 109, 168, 0.1);
    border: 1px solid rgba(255, 109, 168, 0.3);
    border-radius: 8px;
    padding: 8px 10px;
  }
  .account-error.hidden { display: none; }
  .account-btn-primary {
    width: 100%;
    padding: 12px;
    border-radius: 12px;
    border: none;
    background: linear-gradient(135deg, var(--purple), var(--sky));
    color: var(--button-text);
    font-size: 13.5px;
    font-weight: 700;
    cursor: pointer;
    box-shadow: var(--glow-purple);
    transition: transform 0.15s ease;
  }
  .account-btn-primary:hover { transform: translateY(-1px); }
  .account-btn-primary:disabled { opacity: 0.6; cursor: default; transform: none; }
  .account-switch {
    text-align: center;
    font-size: 12.5px;
    color: var(--muted);
    margin: 16px 0 0;
  }
  .account-link-btn {
    background: none;
    border: none;
    color: var(--sky);
    font-weight: 600;
    cursor: pointer;
    padding: 0 0 0 4px;
    font-size: 12.5px;
  }
  .account-link-btn:hover { text-decoration: underline; }
  #account-signedin-email {
    word-break: break-all;
  }

  @media (max-width: 620px) {
    .account-btn { font-size: 12px; padding: 8px 12px; }
  }

  /* ---- recent docs dropdown ---- */
  .recent-docs-wrap { position: relative; }
  .recent-docs-panel {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: 260px;
    max-height: 320px;
    overflow-y: auto;
    background: var(--panel-solid);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: var(--card-shadow);
    padding: 8px;
    z-index: 40;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.16s ease, transform 0.16s ease;
  }
  .recent-docs-panel.hidden {
    opacity: 0;
    transform: translateY(-6px);
    pointer-events: none;
  }
  .recent-docs-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    padding: 6px 8px 8px;
  }
  .recent-docs-clear {
    background: none;
    border: none;
    color: var(--pink);
    font-size: 11px;
    text-transform: none;
    letter-spacing: 0;
    cursor: pointer;
    padding: 2px 4px;
  }
  .recent-docs-clear:hover { text-decoration: underline; }
  .recent-docs-clear.hidden { display: none; }
  .recent-docs-empty {
    font-size: 12.5px;
    color: var(--muted);
    padding: 14px 10px 16px;
    text-align: center;
    line-height: 1.5;
  }
  .recent-docs-empty.hidden { display: none; }
  .recent-docs-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    margin-left: 6px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--purple), var(--sky));
    color: var(--button-text);
    font-size: 10px;
    font-weight: 700;
  }
  .recent-docs-count.hidden { display: none; }
  .recent-docs-list { display: flex; flex-direction: column; gap: 4px; }
  .recent-doc-item {
    display: flex;
    align-items: center;
    gap: 4px;
    border-radius: 10px;
    transition: background 0.15s ease;
  }
  .recent-doc-item:hover { background: var(--panel-soft); }
  .recent-doc-open {
    flex: 1;
    text-align: left;
    background: none;
    border: none;
    padding: 8px 10px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .recent-doc-name {
    font-size: 12.5px;
    color: var(--white);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .recent-doc-meta { font-size: 11px; color: var(--muted); }
  .recent-doc-remove {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 15px;
    cursor: pointer;
    padding: 6px 10px;
    line-height: 1;
  }
  .recent-doc-remove:hover { color: var(--pink); }
</style>
