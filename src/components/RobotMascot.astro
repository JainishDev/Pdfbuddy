---
// src/components/RobotMascot.astro
// "Bit" — the friendly signup-nudge mascot. Markup + styling only;
// all behavior (message sequencing, trigger timing, dismissal) lives in
// src/scripts/robot.ts, wired up from main.ts like every other feature.
---

<div id="bit-mascot" class="bit-mascot hidden" aria-live="polite">
  <div class="bit-bubble" id="bit-bubble">
    <button class="bit-close" id="bit-close" type="button" aria-label="Dismiss">×</button>
    <p class="bit-text" id="bit-text"></p>

    <div class="bit-actions hidden" id="bit-actions">
      <button class="bit-btn bit-btn-primary" id="bit-signup-google" type="button">Continue with Google</button>
      <form class="bit-email-form" id="bit-email-form">
        <input class="bit-input" id="bit-email" type="email" placeholder="Email" autocomplete="email" required />
        <input class="bit-input" id="bit-password" type="password" placeholder="Password" autocomplete="new-password" minlength="6" required />
        <button class="bit-btn" type="submit">Save my stuff</button>
      </form>
      <button class="bit-btn bit-btn-ghost" id="bit-later" type="button">Maybe later</button>
    </div>
  </div>

  <button class="bit-avatar" id="bit-avatar" type="button" aria-label="Bit, your PDF sidekick">
    <svg viewBox="0 0 64 64" width="52" height="52" aria-hidden="true">
      <ellipse class="bit-shadow" cx="32" cy="58" rx="16" ry="3" />
      <rect class="bit-antenna-wire" x="30.5" y="6" width="3" height="10" rx="1.5" />
      <circle class="bit-antenna-tip" cx="32" cy="6" r="4" />
      <rect class="bit-head" x="12" y="16" width="40" height="32" rx="12" />
      <rect class="bit-visor" x="17" y="24" width="30" height="16" rx="8" />
      <circle class="bit-eye" cx="26" cy="32" r="3.6" />
      <circle class="bit-eye" cx="38" cy="32" r="3.6" />
      <path class="bit-smile" d="M 25 37 Q 32 41 39 37" />
      <rect class="bit-ear bit-ear-l" x="8" y="26" width="5" height="12" rx="2.5" />
      <rect class="bit-ear bit-ear-r" x="51" y="26" width="5" height="12" rx="2.5" />
    </svg>
  </button>
</div>

<style>
  .bit-mascot {
    position: fixed;
    top: 84px;
    right: 20px;
    z-index: 60;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .bit-mascot.hidden {
    opacity: 0;
    transform: translateY(-8px);
    pointer-events: none;
  }

  .bit-avatar {
    background: linear-gradient(145deg, var(--panel-solid), var(--panel-soft));
    border: 1px solid var(--border);
    border-radius: 50%;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--glow-purple);
    cursor: pointer;
    animation: bitBob 3.2s ease-in-out infinite;
  }
  .bit-avatar:hover { transform: translateY(-2px); }

  @keyframes bitBob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  .bit-head { fill: var(--panel-solid); stroke: var(--purple); stroke-width: 1.5; }
  .bit-visor { fill: #0b1024; }
  :global(html[data-theme='light']) .bit-visor { fill: #1a2140; }
  .bit-eye { fill: var(--mint); animation: bitBlink 4.6s ease-in-out infinite; transform-origin: center; }
  .bit-eye:nth-of-type(2) { animation-delay: 0.08s; }
  @keyframes bitBlink {
    0%, 92%, 100% { transform: scaleY(1); }
    95% { transform: scaleY(0.1); }
  }
  .bit-smile { fill: none; stroke: var(--sky); stroke-width: 2; stroke-linecap: round; }
  .bit-ear { fill: var(--sky); opacity: 0.85; }
  .bit-antenna-wire { fill: var(--muted); }
  .bit-antenna-tip {
    fill: var(--pink);
    animation: bitWiggle 2.4s ease-in-out infinite;
    transform-origin: 32px 16px;
  }
  @keyframes bitWiggle {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-8deg); }
    75% { transform: rotate(8deg); }
  }
  .bit-shadow { fill: rgba(0, 0, 0, 0.28); }

  .bit-bubble {
    position: relative;
    max-width: 260px;
    background: var(--panel-solid);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 14px 16px;
    box-shadow: var(--card-shadow);
    animation: bitPop 0.25s cubic-bezier(0.2, 0.9, 0.2, 1.2);
  }
  .bit-bubble.hidden { display: none; }
  .bit-bubble::after {
    content: '';
    position: absolute;
    right: 22px;
    bottom: -7px;
    width: 14px;
    height: 14px;
    background: var(--panel-solid);
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transform: rotate(45deg);
  }
  @keyframes bitPop {
    from { opacity: 0; transform: scale(0.9) translateY(6px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .bit-close {
    position: absolute;
    top: 6px;
    right: 8px;
    background: none;
    border: none;
    color: var(--muted);
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    padding: 4px;
  }
  .bit-close:hover { color: var(--white); }

  .bit-text {
    margin: 0 14px 0 0;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--white);
    min-height: 1.4em;
  }
  .bit-text :global(strong) { color: var(--mint); }

  .bit-actions { margin-top: 10px; display: flex; flex-direction: column; gap: 8px; }
  .bit-actions.hidden { display: none; }

  .bit-email-form { display: flex; flex-direction: column; gap: 6px; }
  .bit-input {
    background: var(--panel-soft);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px;
    /* 16px stops iOS Safari's auto-zoom-on-focus */
    font-size: 16px;
    color: var(--white);
  }
  .bit-input:focus { outline: 1px solid var(--sky); }

  .bit-btn {
    font-size: 12.5px;
    font-weight: 600;
    border: none;
    border-radius: 999px;
    padding: 8px 12px;
    cursor: pointer;
    background: var(--panel-soft);
    color: var(--white);
    border: 1px solid var(--border);
    transition: transform 0.15s ease;
  }
  .bit-btn:hover { transform: translateY(-1px); }
  .bit-btn-primary {
    background: linear-gradient(135deg, var(--purple), var(--sky));
    color: var(--button-text);
    border: none;
    box-shadow: var(--glow-purple);
  }
  .bit-btn-ghost { background: transparent; border-color: transparent; color: var(--muted); }

  @media (max-width: 620px) {
    .bit-mascot { right: calc(12px + var(--safe-right, 0px)); top: 112px; }
    .bit-bubble { max-width: min(72vw, 240px); }
    .bit-avatar { width: 52px; height: 52px; }
    .bit-btn { min-height: 40px; }
  }
</style>
