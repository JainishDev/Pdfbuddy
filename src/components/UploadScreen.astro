---
// src/components/UploadScreen.astro
// The "before a document is loaded" screen: mascot, dropzone, status/error states.
// Behavior (drag/drop, file picking, upload request) lives in src/scripts/upload.ts
---

<section id="upload-screen" class="upload-screen">
  <div class="mascot" id="mascot">
    <div class="mascot-glow"></div>
    <div class="mascot-orbit">
      <div class="mascot-satellite"></div>
    </div>
    <div class="mascot-body">
      <div class="mascot-dome">
        <div class="mascot-eye left"></div>
        <div class="mascot-eye right"></div>
      </div>
      <div class="mascot-base"></div>
      <div class="mascot-light l1"></div>
      <div class="mascot-light l2"></div>
      <div class="mascot-light l3"></div>
    </div>
  </div>

  <h1 class="pixel-font upload-title">Drop In A PDF</h1>
  <p class="upload-sub">Upload a file, then ask questions, pull out details, or get a quick summary.</p>

  <div class="feature-strip" aria-label="PDF Buddy capabilities">
    <span>Quick summaries</span>
    <span>Finds key details</span>
    <span>Answers from your file</span>
    <span>Shows useful stats</span>
    <span>Easy re-upload</span>
  </div>

  <div id="dropzone" class="dropzone">
    <input type="file" id="file-input" accept="application/pdf" hidden />
    <div class="dropzone-inner">
      <div class="dz-orbit" aria-hidden="true">
        <span class="dz-planet"></span>
        <span class="dz-ring"></span>
      </div>
      <div class="pixel-font dz-label">Drop PDF Here</div>
      <div class="dz-or">or browse your local files</div>
      <button id="browse-btn" class="btn-primary pixel-font" type="button">Choose File</button>
    </div>
  </div>

  <div id="upload-status" class="upload-status hidden">
    <div class="analysis-card">
      <div class="analysis-orbit">
        <div class="loader-core"></div>
        <div class="loader-moon"></div>
      </div>
      <div class="analysis-copy">
        <div id="upload-status-text" class="pixel-font"></div>
        <div class="analysis-bars" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>
      <ol class="analysis-steps" aria-label="Upload analysis progress">
        <li id="step-upload" class="active">Getting your file</li>
        <li id="step-parse">Reading pages</li>
        <li id="step-index">Organizing notes</li>
        <li id="step-ready">Almost ready</li>
      </ol>
    </div>
  </div>

  <div id="upload-error" class="upload-error hidden"></div>
</section>

<style>
  .upload-screen {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 48px 20px 44px;
    text-align: center;
  }

  .upload-title {
    max-width: 720px;
    font-size: clamp(30px, 6vw, 62px);
    margin: 20px 0 10px;
    line-height: 0.95;
    color: var(--white);
    text-wrap: balance;
  }
  .upload-sub {
    max-width: 620px;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin: 0 0 30px;
  }

  .feature-strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    max-width: 760px;
    margin: 0 0 22px;
  }
  .feature-strip span {
    border: 1px solid var(--border);
    background: var(--panel-soft);
    color: var(--muted);
    border-radius: 999px;
    padding: 7px 11px;
    font-size: 12px;
    line-height: 1;
  }
  :global(html[data-theme='light']) .feature-strip span {
    background: rgba(255, 247, 234, 0.82);
    color: #26324f;
    border-color: rgba(55, 59, 125, 0.24);
  }

  .dropzone {
    position: relative;
    width: min(560px, 92vw);
    border: 1px solid var(--border);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.12), transparent 38%),
      var(--panel);
    backdrop-filter: blur(18px);
    border-radius: var(--radius);
    padding: 34px 24px;
    box-shadow: var(--card-shadow);
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
    overflow: hidden;
  }
  :global(html[data-theme='light']) .dropzone {
    background:
      linear-gradient(135deg, rgba(255, 206, 123, 0.28), transparent 36%),
      linear-gradient(165deg, rgba(211, 238, 241, 0.92), rgba(247, 237, 255, 0.94));
    border-color: rgba(55, 59, 125, 0.32);
  }
  :global(html[data-theme='light']) .dropzone::before {
    background:
      linear-gradient(90deg, transparent 0 22%, rgba(87, 66, 185, 0.11) 22% 23%, transparent 23% 48%, rgba(8, 127, 117, 0.1) 48% 49%, transparent 49%),
      linear-gradient(0deg, transparent 0 30%, rgba(148, 97, 17, 0.08) 30% 31%, transparent 31% 64%, rgba(87, 66, 185, 0.08) 64% 65%, transparent 65%);
  }
  .dropzone::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, transparent 0 22%, rgba(120, 183, 255, 0.09) 22% 23%, transparent 23% 48%, rgba(80, 227, 194, 0.08) 48% 49%, transparent 49%),
      linear-gradient(0deg, transparent 0 30%, rgba(255, 255, 255, 0.055) 30% 31%, transparent 31% 64%, rgba(255, 255, 255, 0.04) 64% 65%, transparent 65%);
    opacity: 0.75;
    pointer-events: none;
  }
  .dropzone:hover,
  .dropzone.drag-over {
    border-color: var(--mint);
    box-shadow: var(--glow-mint), var(--card-shadow);
    transform: translateY(-2px);
  }
  .dropzone-inner { position: relative; display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .dz-orbit { position: relative; width: 76px; height: 76px; margin-bottom: 4px; }
  .dz-planet {
    position: absolute;
    inset: 16px;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--yellow), var(--pink) 52%, var(--purple));
    box-shadow: var(--glow-pink);
  }
  .dz-ring {
    position: absolute;
    left: 4px;
    right: 4px;
    top: 32px;
    height: 14px;
    border: 2px solid rgba(120, 183, 255, 0.72);
    border-left-color: transparent;
    border-right-color: transparent;
    border-radius: 50%;
    transform: rotate(-14deg);
  }
  .dz-label { font-size: 18px; color: var(--white); }
  .dz-or { font-size: 13px; color: var(--muted); margin-bottom: 4px; }

  .btn-primary {
    font-size: 14px;
    min-height: 48px;
    background: linear-gradient(135deg, var(--yellow), var(--pink));
    color: var(--button-text);
    border: none;
    border-radius: 999px;
    padding: 13px 26px;
    box-shadow: var(--glow-pink);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: var(--glow-purple); }
  .btn-primary:active { transform: translateY(0); }

  .upload-status {
    margin-top: 24px;
    width: min(560px, 92vw);
  }
  .analysis-card {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 16px;
    align-items: center;
    text-align: left;
    background:
      linear-gradient(135deg, rgba(80, 227, 194, 0.12), transparent 36%),
      var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--card-shadow);
    padding: 18px;
    overflow: hidden;
  }
  :global(html[data-theme='light']) .analysis-card {
    background:
      linear-gradient(135deg, rgba(0, 111, 107, 0.16), transparent 36%),
      linear-gradient(160deg, rgba(255, 247, 234, 0.92), rgba(229, 224, 255, 0.94));
    border-color: rgba(55, 59, 125, 0.32);
  }
  .analysis-orbit { position: relative; width: 56px; height: 56px; }
  .loader-core {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 14px;
    height: 14px;
    margin: -7px 0 0 -7px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--yellow), var(--pink));
    box-shadow: var(--glow-pink);
  }
  .loader-moon {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    margin: -4px 0 0 -4px;
    border-radius: 50%;
    background: var(--mint);
    box-shadow: var(--glow-mint);
    transform-origin: 4px 4px;
    animation: spinSlow 1.1s linear infinite;
    translate: 20px 0;
  }
  #upload-status-text { font-size: 13px; color: var(--white); letter-spacing: 0.5px; }
  .analysis-copy { min-width: 0; }
  .analysis-bars {
    display: grid;
    gap: 6px;
    margin-top: 10px;
  }
  .analysis-bars span {
    display: block;
    height: 5px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--mint), var(--sky), transparent);
    animation: scanBar 1.35s ease-in-out infinite;
  }
  .analysis-bars span:nth-child(2) { width: 76%; animation-delay: 0.18s; }
  .analysis-bars span:nth-child(3) { width: 52%; animation-delay: 0.36s; }
  @keyframes scanBar {
    0%, 100% { opacity: 0.35; transform: scaleX(0.72); transform-origin: left; }
    50% { opacity: 1; transform: scaleX(1); }
  }
  .analysis-steps {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    padding: 0;
    margin: 4px 0 0;
    list-style: none;
  }
  .analysis-steps li {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 9px 8px;
    color: var(--muted);
    background: var(--panel-soft);
    font-size: 11px;
    text-align: center;
  }
  .analysis-steps li.active,
  .analysis-steps li.done {
    color: var(--white);
    border-color: var(--mint);
    box-shadow: var(--glow-mint);
  }
  .analysis-steps li.done {
    border-color: var(--sky);
    box-shadow: none;
  }

  .upload-error {
    margin-top: 20px;
    color: var(--white);
    background: rgba(255, 95, 184, 0.15);
    border: 1px solid var(--pink);
    border-radius: 14px;
    padding: 14px 18px;
    font-size: 13px;
    max-width: 480px;
  }

  @media (max-width: 560px) {
    .upload-screen {
      justify-content: flex-start;
      padding: 28px 14px 26px;
      padding-left: calc(14px + var(--safe-left, 0px));
      padding-right: calc(14px + var(--safe-right, 0px));
    }
    .mascot { width: 88px; height: 88px; margin-bottom: 10px; }
    .mascot-orbit { inset: -24px; }
    .upload-title { font-size: 34px; line-height: 1; margin-top: 14px; }
    .upload-sub { font-size: 14px; line-height: 1.55; margin-bottom: 18px; }
    .feature-strip { gap: 6px; margin-bottom: 16px; }
    .feature-strip span { font-size: 11px; padding: 6px 9px; }
    .dropzone { width: 100%; padding: 28px 16px; }
    .dz-orbit { width: 64px; height: 64px; }
    .btn-primary { width: 100%; max-width: 320px; }
    .analysis-card { grid-template-columns: 1fr; text-align: center; justify-items: center; }
    .analysis-copy { width: 100%; }
    .analysis-steps { grid-template-columns: 1fr 1fr; }
  }

  /* ---- mascot: the little floating UFO shown above the dropzone ---- */
  .mascot { position: relative; width: 120px; height: 120px; margin-bottom: 18px; animation: floatY 3s ease-in-out infinite; }
  .mascot-glow {
    position: absolute;
    inset: -20px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(155, 107, 255, 0.45), transparent 70%);
    filter: blur(6px);
    animation: twinkle 2.5s ease-in-out infinite;
  }
  .mascot-orbit {
    position: absolute;
    inset: -34px;
    border: 1px dashed rgba(148, 130, 255, 0.35);
    border-radius: 50%;
    animation: spinSlow 9s linear infinite;
  }
  .mascot-satellite {
    position: absolute;
    top: -4px;
    left: 50%;
    width: 8px;
    height: 8px;
    margin-left: -4px;
    border-radius: 50%;
    background: var(--yellow);
    box-shadow: 0 0 12px rgba(255, 210, 63, 0.9);
  }
  .mascot-body { position: relative; width: 100%; height: 100%; }
  .mascot-dome {
    position: relative;
    width: 84px;
    height: 60px;
    margin: 0 auto;
    background: linear-gradient(160deg, #d9f3ff, var(--sky));
    border-radius: 50% 50% 46% 46% / 60% 60% 40% 40%;
    box-shadow: var(--glow-mint), inset 0 -6px 10px rgba(0, 0, 0, 0.15);
  }
  .mascot-eye {
    position: absolute;
    top: 24px;
    width: 12px;
    height: 14px;
    background: var(--ink);
    border-radius: 50%;
    animation: blink 4s infinite;
  }
  .mascot-eye.left { left: 22px; }
  .mascot-eye.right { right: 22px; }
  .mascot-base {
    width: 116px;
    height: 26px;
    margin: -6px auto 0;
    background: linear-gradient(160deg, var(--purple), #6d3fd6);
    border-radius: 50%;
    box-shadow: var(--glow-purple);
  }
  .mascot-light {
    position: absolute;
    bottom: 26px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    animation: twinkle 1.6s ease-in-out infinite;
  }
  .mascot-light.l1 { left: 18px; background: var(--yellow); animation-delay: 0s; }
  .mascot-light.l2 { left: 56px; background: var(--pink); animation-delay: 0.4s; }
  .mascot-light.l3 { right: 18px; background: var(--mint); animation-delay: 0.8s; }
</style>
