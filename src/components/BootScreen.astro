---
// src/components/BootScreen.astro
// Launch-sequence splash shown for ~3s before the app reveals itself.
// Its timing/removal is driven by src/scripts/chrome.ts
---

<div id="boot-screen" class="boot-screen">
  <div class="boot-inner">
    <div class="boot-planet">
      <div class="boot-ring"></div>
    </div>
    <div class="boot-logo pixel-font">
      <span class="l1">PDF</span>
      <span class="l2">BUDDY</span>
    </div>
    <div class="boot-bar-track">
      <div class="boot-bar-fill" id="boot-bar"></div>
    </div>
    <div class="boot-msg" id="boot-msg">LAUNCHING…</div>
  </div>
</div>

<style>
  .boot-screen {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: radial-gradient(ellipse at 50% 40%, #1a1440 0%, #05061a 70%);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.75s ease, transform 0.75s ease, visibility 0.75s ease;
  }
  .boot-screen.boot-leaving {
    opacity: 0;
    visibility: hidden;
    transform: scale(1.025);
    pointer-events: none;
  }
  .boot-inner { text-align: center; padding: 0 24px; }

  .boot-planet {
    width: 64px;
    height: 64px;
    margin: 0 auto 18px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, var(--sky), var(--purple) 70%);
    box-shadow: var(--glow-purple);
    position: relative;
    animation: floatY 3.8s ease-in-out infinite;
  }
  .boot-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 96px;
    height: 24px;
    border: 3px solid var(--mint);
    border-radius: 50%;
    transform: translate(-50%, -50%) rotate(-18deg);
    opacity: 0.8;
    animation: bootRing 5s ease-in-out infinite;
  }
  @keyframes bootRing {
    0%, 100% { transform: translate(-50%, -50%) rotate(-18deg) scaleX(1); opacity: 0.68; }
    50% { transform: translate(-50%, -50%) rotate(-18deg) scaleX(1.12); opacity: 0.95; }
  }

  .boot-logo {
    font-size: clamp(22px, 8vw, 30px);
    line-height: 1.3;
    color: var(--white);
    animation: bootLogoIn 1s ease-out both;
  }
  @keyframes bootLogoIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .boot-logo .l1 { color: var(--yellow); text-shadow: 0 0 18px rgba(255, 210, 63, 0.6); }
  .boot-logo .l2 { color: var(--mint); margin-left: 10px; text-shadow: 0 0 18px rgba(53, 240, 192, 0.6); }

  .boot-bar-track {
    width: min(280px, 100%);
    height: 12px;
    background: var(--panel-solid);
    border: 2px solid var(--border);
    border-radius: 10px;
    margin: 28px auto 12px;
    overflow: hidden;
  }
  .boot-bar-fill {
    height: 100%;
    width: 0%;
    border-radius: 10px;
    background: linear-gradient(90deg, var(--purple), var(--pink), var(--mint));
    background-size: 200% 100%;
    animation: fillBar 3.55s cubic-bezier(0.2, 0.8, 0.2, 1) forwards, gradientShift 2.4s linear infinite;
  }
  @keyframes fillBar { to { width: 100%; } }
  @keyframes gradientShift { to { background-position: 200% 0; } }

  .boot-msg { font-size: 12px; color: var(--sky); letter-spacing: 2px; opacity: 0.85; }
</style>
