---
// src/components/SpaceBackground.astro
// Purely decorative animated backdrop: starfield + drifting nebula
// blobs + shooting stars. Also carries a subtle mouse-parallax effect
// driven by src/scripts/chrome.ts
const shootingStars = [
  { top: '8%', delay: '0s', dur: '6s' },
  { top: '22%', delay: '2.4s', dur: '7.5s' },
  { top: '48%', delay: '5s', dur: '5.5s' },
  { top: '65%', delay: '1.2s', dur: '8s' },
  { top: '80%', delay: '3.6s', dur: '6.8s' },
];
---

<div class="starfield" id="starfield" aria-hidden="true"></div>
<div class="solar-ribbons" aria-hidden="true"></div>
<div class="cosmic-dust" aria-hidden="true"></div>
<div class="sun-core" aria-hidden="true"></div>
<div class="planet planet-main" aria-hidden="true"></div>
<div class="planet planet-small" aria-hidden="true"></div>
<div class="orbit-lane lane-one" aria-hidden="true"></div>
<div class="orbit-lane lane-two" aria-hidden="true"></div>
<div class="nebula nebula-a" id="nebula-a" aria-hidden="true"></div>
<div class="nebula nebula-b" id="nebula-b" aria-hidden="true"></div>
<div class="shooting-stars" aria-hidden="true">
  {shootingStars.map((s) => (
    <span
      class="shooting-star"
      style={`top:${s.top}; animation-delay:${s.delay}; animation-duration:${s.dur};`}
    ></span>
  ))}
</div>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    z-index: -3;
    background:
      radial-gradient(ellipse at 14% 16%, rgba(120, 183, 255, 0.16), transparent 42%),
      radial-gradient(ellipse at 84% 72%, rgba(80, 227, 194, 0.1), transparent 46%),
      linear-gradient(135deg, var(--bg-deep), var(--bg-mid) 58%, #090a19),
      #05061a;
    transform: translate3d(calc(var(--parallax-x, 0) * 6px), calc(var(--parallax-y, 0) * 6px), 0);
    transition: transform 0.4s ease-out;
  }

  .solar-ribbons,
  .cosmic-dust,
  .sun-core {
    position: fixed;
    pointer-events: none;
  }
  .solar-ribbons,
  .cosmic-dust { inset: 0; }
  .solar-ribbons {
    z-index: -2;
    opacity: 0.28;
    background:
      linear-gradient(118deg, transparent 8%, rgba(120, 183, 255, 0.16) 22%, transparent 38%),
      linear-gradient(144deg, transparent 34%, rgba(255, 109, 168, 0.13) 48%, transparent 64%),
      linear-gradient(72deg, transparent 54%, rgba(80, 227, 194, 0.12) 70%, transparent 84%);
    /* Static now: an animated blur() over a full-viewport layer forces a
       repaint of the whole screen every frame, which was the main source
       of the jank/glitching. This layer reads fine without motion. */
  }
  .cosmic-dust {
    z-index: -1;
    opacity: 0.22;
    background-image:
      radial-gradient(3px 3px at 12% 24%, rgba(255, 255, 255, 0.92), transparent),
      radial-gradient(2px 2px at 24% 70%, rgba(120, 183, 255, 0.8), transparent),
      radial-gradient(3px 3px at 44% 16%, rgba(246, 200, 95, 0.85), transparent),
      radial-gradient(2px 2px at 64% 42%, rgba(255, 109, 168, 0.75), transparent),
      radial-gradient(3px 3px at 82% 68%, rgba(80, 227, 194, 0.78), transparent),
      radial-gradient(2px 2px at 92% 22%, rgba(255, 255, 255, 0.82), transparent);
    animation: dustFloat 24s ease-in-out infinite;
    will-change: transform;
  }
  .sun-core {
    z-index: -2;
    width: 260px;
    height: 260px;
    left: min(9vw, 120px);
    top: min(12vh, 120px);
    border-radius: 50%;
    background:
      radial-gradient(circle at 38% 34%, rgba(255, 255, 255, 0.75), transparent 0 16%, transparent 17%),
      radial-gradient(circle, rgba(246, 200, 95, 0.52), rgba(255, 109, 168, 0.16) 48%, transparent 70%);
    opacity: 0.2;
    animation: solarPulse 8s ease-in-out infinite;
    will-change: transform, opacity;
  }
  @keyframes ribbonFlow {
    0%, 100% { transform: translate3d(-2%, 0, 0) scale(1); }
    50% { transform: translate3d(2%, -1%, 0) scale(1.04); }
  }
  @keyframes dustFloat {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(-18px, 14px, 0); }
  }
  @keyframes solarPulse {
    0%, 100% { transform: scale(0.96); opacity: 0.2; }
    50% { transform: scale(1.06); opacity: 0.34; }
  }

  .planet {
    position: fixed;
    z-index: -2;
    pointer-events: none;
    border-radius: 50%;
  }
  .planet-main {
    width: min(34vw, 420px);
    height: min(34vw, 420px);
    right: max(-120px, -8vw);
    top: 14vh;
    background:
      radial-gradient(circle at 32% 28%, rgba(255, 255, 255, 0.38), transparent 0 14%, transparent 15%),
      linear-gradient(145deg, var(--sky), var(--purple) 54%, #1b2453);
    box-shadow: -28px 32px 90px rgba(0, 0, 0, 0.38);
    opacity: 0.72;
  }
  .planet-main::after {
    content: '';
    position: absolute;
    left: -18%;
    right: -18%;
    top: 45%;
    height: 15%;
    border: 2px solid rgba(247, 249, 255, 0.28);
    border-left-color: transparent;
    border-right-color: transparent;
    border-radius: 50%;
    transform: rotate(-15deg);
  }
  .planet-small {
    width: 92px;
    height: 92px;
    left: 7vw;
    bottom: 14vh;
    background: linear-gradient(145deg, var(--yellow), var(--pink) 62%, var(--purple));
    opacity: 0.62;
    box-shadow: var(--glow-pink);
    animation: liveDrift 13s ease-in-out infinite;
    will-change: transform;
  }
  .orbit-lane {
    position: fixed;
    z-index: -2;
    pointer-events: none;
    border: 1px solid rgba(120, 183, 255, 0.16);
    border-radius: 50%;
    transform: rotate(-18deg);
    animation: orbitBreathe 9s ease-in-out infinite;
    will-change: transform, opacity;
  }
  .lane-one {
    width: 58vw;
    height: 18vw;
    min-width: 480px;
    min-height: 150px;
    right: -18vw;
    top: 20vh;
  }
  .lane-two {
    width: 38vw;
    height: 12vw;
    min-width: 320px;
    min-height: 100px;
    left: -11vw;
    bottom: 18vh;
    animation-delay: 2.5s;
  }
  @keyframes orbitBreathe {
    0%, 100% { opacity: 0.35; scale: 1; }
    50% { opacity: 0.7; scale: 1.025; }
  }
  @keyframes liveDrift {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(18px, -12px, 0); }
  }
  .starfield::before,
  .starfield::after {
    content: '';
    position: absolute;
    inset: -200px;
    background-image: radial-gradient(2px 2px at 20px 30px, #fff, transparent),
      radial-gradient(1.5px 1.5px at 120px 90px, #fff, transparent),
      radial-gradient(2px 2px at 220px 40px, rgba(255, 255, 255, 0.9), transparent),
      radial-gradient(1px 1px at 300px 150px, rgba(255, 255, 255, 0.8), transparent),
      radial-gradient(2px 2px at 400px 60px, #fff, transparent),
      radial-gradient(1.5px 1.5px at 60px 200px, rgba(255, 255, 255, 0.85), transparent),
      radial-gradient(1.5px 1.5px at 500px 250px, #fff, transparent),
      radial-gradient(2px 2px at 180px 280px, rgba(255, 255, 255, 0.8), transparent);
    background-repeat: repeat;
    background-size: 560px 320px;
    opacity: 0.8;
    animation: driftStars 90s linear infinite;
  }
  .starfield::after {
    background-size: 720px 420px;
    opacity: 0.45;
    animation: driftStars 140s linear infinite reverse;
  }
  @keyframes driftStars {
    from { transform: translate3d(0, 0, 0); }
    to { transform: translate3d(-560px, -320px, 0); }
  }

  .nebula {
    position: fixed;
    z-index: -2;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.35;
    pointer-events: none;
    animation: nebulaDrift 22s ease-in-out infinite;
    will-change: transform;
  }
  .nebula-a {
    width: 420px;
    height: 420px;
    top: -120px;
    left: -100px;
    background: radial-gradient(circle, var(--purple), transparent 70%);
    translate: calc(var(--parallax-x, 0) * -14px) calc(var(--parallax-y, 0) * -14px);
  }
  .nebula-b {
    width: 380px;
    height: 380px;
    bottom: -140px;
    right: -100px;
    background: radial-gradient(circle, var(--mint), transparent 70%);
    animation-delay: 4s;
    translate: calc(var(--parallax-x, 0) * 18px) calc(var(--parallax-y, 0) * 18px);
  }
  @keyframes nebulaDrift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(30px, -20px) scale(1.08); }
  }

  /* daytime galaxy: same structure, much softer */
  :global(html[data-theme='light']) .starfield {
    background:
      radial-gradient(ellipse at 12% 12%, rgba(255, 188, 92, 0.74), transparent 28%),
      radial-gradient(ellipse at 70% 18%, rgba(119, 82, 221, 0.38), transparent 40%),
      radial-gradient(ellipse at 82% 76%, rgba(0, 136, 150, 0.3), transparent 46%),
      radial-gradient(ellipse at 28% 88%, rgba(218, 59, 121, 0.24), transparent 42%),
      linear-gradient(145deg, #f7c778 0%, #94cde7 32%, #9c93e9 68%, #80cfc9 100%),
      #94cde7;
  }
  :global(html[data-theme='light']) .starfield::before,
  :global(html[data-theme='light']) .starfield::after {
    opacity: 0.28;
    filter: sepia(0.25) saturate(1.5) hue-rotate(175deg) brightness(0.82);
  }
  :global(html[data-theme='light']) .solar-ribbons {
    opacity: 0.68;
    background:
      linear-gradient(116deg, transparent 6%, rgba(255, 178, 91, 0.42) 20%, transparent 38%),
      linear-gradient(142deg, transparent 30%, rgba(96, 67, 210, 0.34) 48%, transparent 66%),
      linear-gradient(74deg, transparent 52%, rgba(0, 126, 119, 0.28) 70%, transparent 86%);
  }
  :global(html[data-theme='light']) .cosmic-dust {
    opacity: 0.44;
    mix-blend-mode: multiply;
  }
  :global(html[data-theme='light']) .sun-core {
    opacity: 0.55;
  }
  :global(html[data-theme='light']) .nebula {
    opacity: 0.3;
    filter: blur(62px) saturate(1.3);
  }
  :global(html[data-theme='light']) .planet-main {
    opacity: 0.7;
    background:
      radial-gradient(circle at 30% 26%, rgba(255, 255, 255, 0.48), transparent 0 13%, transparent 14%),
      linear-gradient(145deg, #ffb86b, #c06cff 48%, #2c83b9);
    box-shadow: -24px 32px 80px rgba(76, 74, 145, 0.2);
  }
  :global(html[data-theme='light']) .planet-small {
    opacity: 0.68;
    background: linear-gradient(145deg, #ffd36c, #ef6a91 58%, #7258d9);
  }
  :global(html[data-theme='light']) .orbit-lane {
    border-color: rgba(87, 66, 185, 0.24);
  }

  /* ---- shooting stars: a handful of comets streaking across the sky
     on staggered loops, purely decorative, purely CSS ---- */
  .shooting-stars {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }
  .shooting-star {
    position: absolute;
    left: -10%;
    width: 140px;
    height: 2px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0));
    filter: drop-shadow(0 0 6px rgba(255, 255, 255, 0.8));
    transform: rotate(18deg);
    opacity: 0;
    animation-name: shoot;
    animation-timing-function: ease-in;
    animation-iteration-count: infinite;
  }
  @keyframes shoot {
    0% { transform: translate(0, 0) rotate(18deg); opacity: 0; }
    5% { opacity: 1; }
    18% { transform: translate(130vw, 60px) rotate(18deg); opacity: 0; }
    100% { transform: translate(130vw, 60px) rotate(18deg); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .shooting-star { display: none; }
    .planet-small,
    .orbit-lane,
    .nebula,
    .solar-ribbons,
    .cosmic-dust,
    .sun-core { animation: none; }
  }
</style>
