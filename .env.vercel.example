# === PDF Buddy — Vercel Environment Variables ===
# Copy these to your Vercel Project Settings → Environment Variables
# NEVER commit real values — use Vercel Dashboard to add them.

# ── AI (at least one required for AI-powered answers) ──────────────────────
# Gemini: get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Firebase Client (PUBLIC — safe to expose; restrict by domain in console) ─
# Required to enable the Sign In button (Google + email/password).
# Without these the app still works fully — login button shows a notice instead.
# Get these from your Firebase project settings → Web app config.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (SERVER ONLY — keep secret, never commit real values) ────
# Required for server-side token verification.
# Get these from Firebase console → Project Settings → Service Accounts
# → Generate new private key. Paste the JSON values below.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private key value exactly as it appears in the JSON (with \n escape sequences).
FIREBASE_ADMIN_PRIVATE_KEY=